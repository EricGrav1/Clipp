DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Clerk auth. Leave blank in local-only development to use the dev-user fallback.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Optional owner email used to claim local dev projects after the first Clerk sign-in.
FOUNDER_EMAIL="EricGrav1@icloud.com"

# Stripe Billing. When these are blank, local development treats the dev user as active.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_MONTHLY_PRICE_ID=""
STRIPE_YEARLY_PRICE_ID=""

# Cloudflare R2 / S3-compatible media storage. Leave blank to use local public/uploads and public/clips.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""

# Ayrshare-style social scheduling provider. Leave blank locally to use demo social connections.
AYRSHARE_API_KEY=""
AYRSHARE_PRIVATE_KEY=""
AYRSHARE_JWT_DOMAIN=""
AYRSHARE_API_BASE_URL="https://api.ayrshare.com/api"
SOCIAL_WEBHOOK_SECRET=""

# Optional shared secret for an external render worker calling /api/internal/render-jobs/[jobId].
RENDER_WORKER_SECRET=""
