generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id            String   @id @default(cuid())
  userAccountId String?
  name          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userAccount UserAccount? @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  video Video?
  clips Clip[]

  @@index([userAccountId, updatedAt])
}

model UserAccount {
  id                   String   @id @default(cuid())
  clerkUserId          String   @unique
  email                String?
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  subscriptionStatus   String   @default("inactive")
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  renderMinutesLimit   Int      @default(120)
  renderSecondsUsed    Int      @default(0)
  onboardingCompletedAt DateTime?
  onboardingAnswers     Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  projects Project[]
  socialConnections SocialConnection[]
  scheduledPosts ScheduledPost[]
}

model Video {
  id              String   @id @default(cuid())
  projectId       String   @unique
  originalName    String
  mimeType        String
  fileName        String
  url             String
  path            String?
  objectKey       String?
  storageProvider String @default("local")
  sizeBytes       BigInt
  durationSeconds Float?
  mediaExpiresAt  DateTime?
  mediaDeletedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clips   Clip[]

  @@index([mediaExpiresAt, mediaDeletedAt])
}

model Clip {
  id        String     @id @default(cuid())
  projectId String
  videoId   String
  title     String
  startTime Float
  endTime   Float
  duration  Float
  status    String   @default("RENDERING")
  fileName  String?
  url       String?
  path      String?
  objectKey String?
  storageProvider String @default("local")
  error     String?
  mediaExpiresAt  DateTime?
  mediaDeletedAt  DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  video   Video   @relation(fields: [videoId], references: [id], onDelete: Cascade)
  renderJob RenderJob?
  scheduledPosts ScheduledPost[]

  @@index([projectId, createdAt])
  @@index([mediaExpiresAt, mediaDeletedAt])
}

model RenderJob {
  id        String   @id @default(cuid())
  clipId    String   @unique
  status    String   @default("QUEUED")
  attempts  Int      @default(0)
  error     String?
  queuedAt  DateTime @default(now())
  startedAt DateTime?
  finishedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clip Clip @relation(fields: [clipId], references: [id], onDelete: Cascade)
}

model SocialConnection {
  id                 String   @id @default(cuid())
  userAccountId      String
  provider           String   @default("ayrshare")
  providerProfileId  String?
  providerProfileKey String?
  connectedPlatforms String   @default("[]")
  status             String   @default("DISCONNECTED")
  metadata           String   @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userAccount UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)

  @@unique([userAccountId, provider])
  @@index([providerProfileId])
}

model ScheduledPost {
  id                String   @id @default(cuid())
  userAccountId     String
  clipId            String
  provider          String   @default("ayrshare")
  providerPostId    String?
  selectedPlatforms String
  sharedCaption     String
  platformOverrides String   @default("{}")
  scheduledAt       DateTime
  timezone          String
  status            String   @default("SCHEDULING")
  providerResponse  String   @default("{}")
  failureReason     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  userAccount UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)
  clip        Clip        @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@index([userAccountId, scheduledAt])
  @@index([clipId, scheduledAt])
  @@index([providerPostId])
}
